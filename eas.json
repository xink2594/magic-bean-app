{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "applicationIdSuffix": ".develop"
      },
      "env": {
        "APP_DISPLAY_NAME": "Magic Bean Dev"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "applicationIdSuffix": ".preview"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "APP_DISPLAY_NAME": "Magic Bean Preview"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
